rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CASTRO NEPAL SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset implements a hybrid security model designed for an e-commerce platform. It balances 
     * public accessibility for product catalogs with strict private ownership for user data and orders.
     * Administrative access is managed via a database-backed role system.
     * 
     * Data Structure:
     * - Public Collections: /products, /categories, and /announcements are publicly readable.
     * - User Data: /userProfiles/{userId} is strictly private to the authenticated owner.
     * - Transactional Data: /orders and /orders/{id}/orderItems use a denormalized ownership model.
     * - Access Control: /roles_admin/{userId} defines global administrative privileges.
     * 
     * Key Security Decisions:
     * - Denormalization for Authorization: To ensure high performance and "Authorization Independence," 
     *   the 'userId' is denormalized onto Order and OrderItem documents. This allows for direct ownership 
     *   checks without costly get() calls to parent documents or profiles.
     * - Admin Elevation: Admin status is verified by checking for the existence of a document in 
     *   the /roles_admin collection matching the user's UID.
     * - Prototyping Flexibility: Rules enforce strict authorization (WHO can access) but remain 
     *   flexible on data schema (WHAT is stored) to facilitate rapid development.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is made by an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user has administrative privileges via the DBAC collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Validates ownership for existing documents during update or delete. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Public catalog of gaming products and redeem codes.
     * @path /products/{productId}
     * @allow get, list (public)
     * @allow create, update, delete (Admin only)
     * @principle Public read-only access for customers with restricted administrative writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Product categories for navigation and filtering.
     * @path /categories/{categoryId}
     * @allow get, list (public)
     * @allow create, update, delete (Admin only)
     * @principle Homogeneous security posture for public navigation data.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description System-wide announcements for the storefront.
     * @path /announcements/{announcementId}
     * @allow get, list (public)
     * @allow create, update, delete (Admin only)
     * @principle Ensures marketing content is publicly visible but only modifiable by staff.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Private user profile information.
     * @path /userProfiles/{userId}
     * @allow get, list, create, update (Owner or Admin)
     * @deny delete (Prevent accidental account deletion via client)
     * @principle Path-based ownership ensures users only manage their own profile data.
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Users shouldn't list all profiles; Admins can.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Customer purchase transactions.
     * @path /orders/{orderId}
     * @allow get, list (Owner or Admin)
     * @allow create (Authenticated user for self)
     * @principle Uses denormalized userId field for efficient ownership validation.
     */
    match /orders/{orderId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100); // Standard list protection, filtering enforced by app logic
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin(); // Users generally shouldn't modify orders after placement.
      allow delete: if isAdmin();
    }

    /**
     * @description Specific line items within a customer order.
     * @path /orders/{orderId}/orderItems/{orderItemId}
     * @allow get, list (Owner or Admin)
     * @principle Relies on denormalized userId on the item itself to avoid parent document lookups.
     */
    match /orders/{orderId}/orderItems/{orderItemId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    /**
     * @description Registry of users with administrative privileges.
     * @path /roles_admin/{userId}
     * @allow get (Self or Admin)
     * @deny list, create, update, delete (System managed)
     * @principle Provides the source of truth for all 'isAdmin()' checks across the database.
     */
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if false; // Admin roles should be managed via Firebase Console or Admin SDK
    }

  }
}