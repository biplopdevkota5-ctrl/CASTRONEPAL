rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a robust, multi-layered authorization model for Castro Nepal, a digital gaming marketplace.
     * The security posture follows a "Strict Authorization, Flexible Schema" approach, prioritizing 
     * identity verification and path-based ownership while allowing for rapid data structure iteration.
     *
     * DATA STRUCTURE
     * 1. User-Centric: Private profiles and order histories are nested under /users/{userId}.
     * 2. Catalog: Publicly readable collections include /categories, /products, and /announcements.
     * 3. Segregation: Orders are split into /users/{userId}/orders (authenticated) and /guest_orders (unauthenticated/admin-only).
     * 4. Admin Control: System-wide write access is gated by the existence of a record in the /roles_admin/{uid} collection.
     *
     * KEY DECISIONS
     * - Authorization Independence: Rules rely on path parameters and internal document IDs (denormalized) 
     *   to verify ownership without needing expensive cross-document lookups.
     * - Admin-Overrides: Administrators have broad access to order management and catalog maintenance.
     * - Relational Integrity: On creation, we enforce that document-level link fields (like userId or orderId) 
     *   match the document's location in the hierarchy.
     */

    /* --- GLOBAL HELPER FUNCTIONS --- */

    // Checks if the request is made by a signed-in user.
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the authenticated user's UID matches a specific userId.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the current user is an administrator via DBAC (Database-Backed Access Control).
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Combines admin check with existence check for destructive operations.
    // NOTE: 'resource != null' is redundant for delete operations where this function is used,
    // as 'resource' is always non-null for existing documents.
    // Simplified to address "Invalid variable name: resource" warning.
    function isExistingAdmin() {
      return isAdmin();
    }

    /* --- COLLECTION RULES --- */

    /**
     * @description Rules for the UserProfile collection. Users can only access and modify their own profile.
     * @path /users/{userId}
     * @allow (get/list/update) if auth.uid == userId
     * @deny (create) if the internal 'id' field does not match the userId in the path.
     * @principle Enforces document ownership and path-to-data consistency.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; // User profiles should not be deleted via the client for audit purposes.
    }

    /**
     * @description Rules for user-owned Orders. Authenticated users manage their own orders; admins manage all.
     * @path /users/{userId}/orders/{orderId}
     * @allow (create) if userId matches auth.uid and internal userId field is set correctly.
     * @deny (update) if an unauthorized user attempts to change order status.
     * @principle Uses path-based authorization and ensures relational immutability.
     */
    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingAdmin();
      
      /**
       * @description Rules for OrderItems nested under user orders.
       * @path /users/{userId}/orders/{orderId}/order_items/{orderItemId}
       * @allow (list) if the user owns the parent order path.
       * @deny (create) if the orderId in the data does not match the path.
       * @principle Inherits security from the parent path structure.
       */
      match /order_items/{orderItemId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.orderId == orderId;
        allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.orderId == resource.data.orderId;
        allow delete: if isExistingAdmin();
      }
    }

    /**
     * @description Rules for Guest Orders. These are isolated from authenticated user paths.
     * @path /guest_orders/{orderId}
     * @allow (create) if the request is anonymous or signed in (guests can be both).
     * @deny (get/list/update) to anyone except administrators.
     * @principle Structural segregation of guest data for sensitive admin-only oversight.
     */
    match /guest_orders/{orderId} {
      allow get, list, update, delete: if isAdmin();
      allow create: if true; // Allows the checkout process to submit orders.
      
      match /order_items/{orderItemId} {
        allow get, list, update, delete: if isAdmin();
        allow create: if true;
      }
    }

    /**
     * @description Product Catalog: Categories. Publicly readable, admin-only writes.
     * @path /categories/{categoryId}
     * @allow (get/list) if true.
     * @deny (update) if the user is not an administrator.
     * @principle Public consumption with strictly gated administrative management.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Product Catalog: Products. Publicly readable, admin-only writes.
     * @path /products/{productId}
     * @allow (list) for all users to browse the store.
     * @deny (create) for non-admin users.
     * @principle Public consumption with strictly gated administrative management.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description System Announcements. Publicly readable, admin-only writes.
     * @path /announcements/{announcementId}
     * @allow (get) for all users to see site-wide news.
     * @deny (delete) for non-admin users.
     * @principle Public consumption with strictly gated administrative management.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Admin Role Registry. Used for DBAC lookup.
     * @path /roles_admin/{uid}
     * @allow (get) for signed-in users to verify their own role.
     * @deny (list/write) for all users; managed via Admin SDK/Console.
     * @principle Protects the authority source of the system.
     */
    match /roles_admin/{uid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }
  }
}