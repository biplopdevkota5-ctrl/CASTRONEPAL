
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * APPLICATION SECURITY STRATEGY: Castro Nepal E-commerce
     * Admin access is granted to signed-in users because the admin panel
     * is password-protected on the client.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For the prototype, we allow authenticated users to perform admin writes
      // as they must bypass the client-side password check first.
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow write: if false;
    }

    match /user_profiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow create: if true; // Allow guest checkout
      allow update, delete: if isAdmin();
    }

    match /orders/{orderId}/items/{orderItemId} {
      allow get, list: if isSignedIn(); 
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      // Explicitly allow public read for the homepage display
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
