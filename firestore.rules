
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * APPLICATION SECURITY STRATEGY: Castro Nepal E-commerce
     * For the prototype phase, we allow full read/write access to ensure 
     * reliable data visibility across all environments.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
