
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A gaming product or digital code available in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["PlayStation", "Xbox", "Steam", "Nintendo", "GPU", "PC", "Mobile"] },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Base64 encoded image or URL" },
        "status": { "type": "string", "enum": ["In Stock", "Out of Stock", "Low Stock"] },
        "features": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "status"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Store updates and news displayed on the home page.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "date"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Delivered", "Cancelled"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "customerPhone", "productId", "totalPrice", "status"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Collection of store products."
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Collection of store announcements."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Collection of customer orders."
    }
  }
}
